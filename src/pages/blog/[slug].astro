---

<Layout>
  <Header />
  <div id="container">
    <main>
      <article>
        <a href="/blog" class="back">← Back to Blog</a>

        <header class="post-header">
          <h1>Post coming soon</h1>
          <p class="description">This article is still being drafted. Check back shortly.</p>
        </header>

        {/*
        <header class="post-header">
          <div class="post-meta">
            <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
            {post.data.tags && post.data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <h1>{post.data.title}</h1>
          <p class="description">{post.data.description}</p>
        </header>

        <div class="prose">
          <Content />
        </div>
        */}
      </article>
    </main>
  </div>
  <Footer />
</Layout>

<style>
  #container {
    min-height: 100vh;
  }

  main {
    min-height: 100vh;
    display: flex;
    justify-content: center;
    padding: 20px;
    margin-top: 100px;
  }

  article {
    max-width: 720px;
    width: 100%;
    padding: 16px;
  }

  .back {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: var(--accent-strong);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s ease;
  }

  .back:hover {
    color: var(--primary);
  }

  .post-header {
    margin-bottom: 40px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  time {
    font-size: 13px;
    color: var(--text-muted);
    font-weight: 500;
  }

  .tag {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    background: var(--accent-soft);
    border: 1px solid var(--accent);
    color: var(--accent-strong);
  }

  h1 {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--primary);
    margin: 0 0 12px;
  }

  .description {
    font-size: 18px;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Prose styles for markdown content */
  .prose {
    color: var(--text);
    font-size: 17px;
    line-height: 1.8;
  }

  .prose :global(h2) {
    font-size: 26px;
    font-weight: 600;
    color: var(--primary);
    margin: 2em 0 0.75em;
    letter-spacing: -0.01em;
  }

  .prose :global(h3) {
    font-size: 20px;
    font-weight: 600;
    color: var(--primary);
    margin: 1.75em 0 0.5em;
  }

  .prose :global(p) {
    margin: 0 0 1.4em;
  }

  .prose :global(a) {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: var(--primary);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5em;
    margin: 0 0 1.4em;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
  }

  .prose :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    background: var(--primary-soft);
    color: var(--primary);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    overflow-x: auto;
    margin: 0 0 1.4em;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 14px;
    color: var(--text);
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 0 0 1.4em;
    padding: 8px 0 8px 20px;
    color: var(--text-muted);
    font-style: italic;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2em 0;
  }

  @media (max-width: 480px) {
    main {
      margin-top: 80px;
      padding: 10px;
    }

    .prose {
      font-size: 16px;
    }
  }
</style>
