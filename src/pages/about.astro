---
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { experiences } from '../data/experiences.ts';
import { education } from '../data/education.ts';
import { bio } from '../data/bio.ts';
---

<Layout>
	<Header />
	<div id="container">
		<main>
			<div id="content">

				<h1>About Me</h1>
				{bio.aboutIntro.map(paragraph => <p class="intro">{paragraph}</p>)}

				<!-- Experience -->
				<h2 class="section-heading">Experience</h2>
				<div class="timeline">
					{experiences.map(exp => (
						<div class="timeline-entry">
							<div class="timeline-marker">
								<span class="dot"></span>
							</div>
							<section class="exp-card">
								<div class="exp-header">
									<div class="exp-left">
										{(exp.logoUrl || exp.logoIconName) && (
											<div class="org-logo">
												{exp.logoUrl
													? <img src={exp.logoUrl} alt={exp.org} />
													: <Icon name={exp.logoIconName!} />
												}
											</div>
										)}
										<div class="titles">
											<h3>{exp.role}</h3>
											<p class="org">{exp.org}</p>
										</div>
									</div>
									<div class="meta">
										<span class="date">{exp.dates}</span>
										<span class="location">{exp.location}</span>
									</div>
								</div>

								<p class="summary" set:html={exp.summary}></p>

								{exp.highlights && exp.highlights.length > 0 && (
									<ul class="highlights">
										{exp.highlights.map(point => (
											<li set:html={point}></li>
										))}
									</ul>
								)}

								{exp.tech && exp.tech.length > 0 && (
									<div class="tags">
										{exp.tech.map(tag => (
											<span class="tag">
												<span class="tag-icon">
													<Icon name={tag.iconName} />
												</span>
												<span class="tag-name">{tag.name}</span>
											</span>
										))}
									</div>
								)}
							</section>
						</div>
					))}
				</div>

				<!-- Education -->
				<h2 class="section-heading">Education</h2>
				<div class="timeline">
					{education.map(edu => (
						<div class="timeline-entry">
							<div class="timeline-marker">
								<span class="dot"></span>
							</div>
							<section class="exp-card">
								<div class="exp-header">
									<div class="titles">
										<h3>{edu.degree}</h3>
										<p class="org">{edu.institution}</p>
									</div>
									<div class="meta">
										<span class="date">{edu.dates}</span>
										<span class="location">{edu.location}</span>
									</div>
								</div>
								{edu.details && edu.details.length > 0 && (
									<ul class="highlights">
										{edu.details.map(d => <li>{d}</li>)}
									</ul>
								)}
							</section>
						</div>
					))}
				</div>

				<!-- Anime & Manga -->
				<h2 class="section-heading">Anime &amp; Manga</h2>
				<div class="anime-section">
					<p class="anime-blurb">I track everything I watch and read. Find me on:</p>
					<div class="anime-links">
						<a href={bio.anime.anilist.url} target="_blank" rel="noopener noreferrer" class="anime-card anilist">
							<Icon name="simple-icons:anilist" class="anime-icon" />
							<div>
								<span class="anime-platform">AniList</span>
								<span class="anime-username">@{bio.anime.anilist.username}</span>
							</div>
						</a>
						<a href={bio.anime.mal.url} target="_blank" rel="noopener noreferrer" class="anime-card mal">
							<Icon name="simple-icons:myanimelist" class="anime-icon" />
							<div>
								<span class="anime-platform">MyAnimeList</span>
								<span class="anime-username">@{bio.anime.mal.username}</span>
							</div>
						</a>
					</div>
				</div>

					<!-- Socials -->
					<h2 class="section-heading">Socials</h2>
					<div class="socials-section">
						{bio.socials.length === 0 ? (
							<p class="socials-empty">More links coming soon.</p>
						) : (
							<div class="socials-links">
								{bio.socials.map(social => (
									<a href={social.url} target="_blank" rel="noopener noreferrer" class="social-card">
										<Icon name={social.iconName} class="social-icon" />
										<div>
											<span class="social-platform">{social.platform}</span>
											{social.username && <span class="social-username">@{social.username}</span>}
										</div>
									</a>
								))}
							</div>
						)}
					</div>

			</div>
		</main>
	</div>
	<Footer />
</Layout>

<style>
	#container {
		min-height: 100vh;
	}

	main {
		min-height: 100vh;
		display: flex;
		justify-content: center;
		padding: 20px;
		margin-top: 100px;
	}

	#content {
		max-width: 1000px;
		width: 100%;
		padding: 16px;
	}

	h1 {
		font-size: 48px;
		margin-bottom: 12px;
		color: var(--primary);
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.intro {
		color: var(--text-muted);
		font-size: 18px;
		line-height: 1.6;
		margin-bottom: 48px;
	}

	.section-heading {
		font-size: 22px;
		font-weight: 700;
		color: var(--text);
		letter-spacing: -0.01em;
		margin: 0 0 20px;
		padding-bottom: 10px;
		border-bottom: 2px solid var(--border);
	}

	/* Timeline */
	.timeline {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 20px;
		margin-bottom: 48px;
	}

	.timeline::before {
		content: '';
		position: absolute;
		left: 9px;
		top: 0;
		bottom: 0;
		width: 2px;
		background: linear-gradient(to bottom, transparent, var(--accent) 8%, var(--primary) 92%, transparent);
		border-radius: 1px;
	}

	.timeline-entry {
		display: grid;
		grid-template-columns: 20px 1fr;
		gap: 16px;
		align-items: center;
	}

	.timeline-marker {
		display: flex;
		justify-content: center;
		align-items: center;
		position: relative;
		z-index: 1;
		align-self: stretch;
	}

	.dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: var(--accent);
		border: 2px solid var(--bg-base);
		outline: 2px solid var(--accent);
		flex-shrink: 0;
		transition: background 0.25s ease, outline-color 0.25s ease;
	}

	.timeline-entry:hover .dot {
		background: var(--primary);
		outline-color: var(--primary);
	}

	.exp-card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		border-radius: 8px 16px 16px 8px;
		padding: 24px;
		box-shadow: 0 4px 12px var(--shadow);
		backdrop-filter: blur(10px);
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
		will-change: transform;
		transform: translateZ(0);
	}

	.timeline-entry:hover .exp-card {
		transform: translateX(4px);
		box-shadow: 0 8px 22px var(--shadow-strong);
		border-left-color: var(--primary);
	}

	.exp-header {
		display: flex;
		justify-content: space-between;
		gap: 12px;
		flex-wrap: wrap;
		margin-bottom: 12px;
		align-items: center;
	}

	.exp-left {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.org-logo {
		display: flex;
		align-items: center;
		flex-shrink: 0;
	}

	.org-logo :global(svg),
	.org-logo img {
		width: 36px;
		height: 36px;
		object-fit: contain;
	}

	.titles h3 {
		margin: 0;
		font-size: 20px;
		color: var(--primary);
		font-weight: 600;
	}

	.titles .org {
		margin: 4px 0 0;
		color: var(--accent-strong);
		font-weight: 600;
		font-size: 14px;
	}

	.meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 4px;
	}

	.date {
		font-size: 13px;
		font-weight: 600;
		color: var(--primary);
		background: var(--primary-soft);
		padding: 2px 10px;
		border-radius: 20px;
		white-space: nowrap;
	}

	.location {
		font-size: 12px;
		color: var(--text-muted);
		text-align: right;
	}

	.summary {
		margin: 0 0 12px;
		color: var(--text);
		line-height: 1.65;
		font-size: 15px;
	}

	.highlights {
		margin: 0 0 16px 0;
		padding-left: 18px;
		color: var(--text);
		line-height: 1.65;
		font-size: 15px;
	}

	.highlights li {
		margin-bottom: 6px;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.tag {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 4px 12px;
		background: var(--accent-soft);
		border: 1px solid var(--accent);
		border-radius: 12px;
		font-size: 12px;
		font-weight: 600;
		color: var(--accent-strong);
	}

	.tag-icon :global(svg) {
		width: 14px;
		height: 14px;
		flex-shrink: 0;
	}

	.tag-name {
		line-height: 1;
	}

	/* Anime section */
	.anime-section {
		margin-bottom: 48px;
	}

	.anime-blurb {
		color: var(--text-muted);
		font-size: 15px;
		margin: 0 0 16px;
	}

	.anime-links {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	.anime-card {
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 16px 24px;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		text-decoration: none;
		box-shadow: 0 4px 12px var(--shadow);
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
		min-width: 200px;
	}

	.anime-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 20px var(--shadow-strong);
		border-color: var(--border-strong);
	}

	.anime-icon :global(svg) {
		width: 32px;
		height: 32px;
		flex-shrink: 0;
	}

	.anilist .anime-icon :global(svg) {
		color: #02a9ff;
	}

	.mal .anime-icon :global(svg) {
		color: #2e51a2;
	}

	.anime-platform {
		display: block;
		font-size: 15px;
		font-weight: 700;
		color: var(--text);
	}

	.anime-username {
		display: block;
		font-size: 13px;
		color: var(--text-muted);
	}

	/* Socials section */
	.socials-section {
		margin-bottom: 48px;
	}

	.socials-empty {
		color: var(--text-muted);
		font-size: 15px;
		margin: 0;
	}

	.socials-links {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	.social-card {
		display: flex;
		align-items: center;
		gap: 14px;
		padding: 16px 24px;
		border-radius: 12px;
		border: 1px solid var(--border);
		background: var(--surface);
		text-decoration: none;
		box-shadow: 0 4px 12px var(--shadow);
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
		min-width: 200px;
	}

	.social-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 20px var(--shadow-strong);
		border-color: var(--border-strong);
	}

	.social-icon :global(svg) {
		width: 32px;
		height: 32px;
		flex-shrink: 0;
		color: var(--accent-strong);
	}

	.social-platform {
		display: block;
		font-size: 15px;
		font-weight: 700;
		color: var(--text);
	}

	.social-username {
		display: block;
		font-size: 13px;
		color: var(--text-muted);
	}

	@media (max-width: 768px) {
		h1 {
			font-size: 36px;
		}

		.timeline-entry {
			gap: 12px;
		}

		.exp-card {
			padding: 18px;
		}
	}

	@media (max-width: 480px) {
		main {
			margin-top: 80px;
			padding: 10px;
		}

		h1 {
			font-size: 30px;
		}

		.exp-header {
			flex-direction: column;
			align-items: flex-start;
		}

		.meta {
			align-items: flex-start;
		}

		.anime-card,
		.social-card {
			min-width: unset;
			width: 100%;
		}
	}
</style>
