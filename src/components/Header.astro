---
import profilePic from '../assets/bucchi.png';
const path = Astro.url.pathname;
---

<script is:inline>
  document.addEventListener('astro:after-swap', function () {
    const theme = localStorage.getItem('theme') ?? 'dark'
    document.documentElement.classList.toggle('dark', theme === 'dark')
  })

  const getThemePreference = () => {
    return localStorage.getItem('theme') ?? 'dark'
  }

  const isDark = getThemePreference() === 'dark'
  document.documentElement.classList[isDark ? 'add' : 'remove']('dark')

  // Theme toggle functionality
  document.addEventListener('DOMContentLoaded', function() {
    const themeToggle = document.getElementById('theme-toggle')
    const updateToggleText = () => {
      if (document.documentElement.classList.contains('dark')) {
        themeToggle.textContent = '☀️'
      } else {
        themeToggle.textContent = '🌙'
      }
    }
    
    updateToggleText()
    
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark')
      document.documentElement.classList.toggle('dark', !isDark)
      localStorage.setItem('theme', isDark ? 'light' : 'dark')
      updateToggleText()
    })
  })
</script>

<header>
	<div class="container flex h-16 items-center justify-between space-x-4 sm:space-x-0">
		<div class="profile-section">
			<a class="avatar-link" href="https://github.com/avinight" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">
				<img src={profilePic.src} alt="Profile Picture" class="avatar-img" />
			</a>
			<span class="profile-name">Frederick Meneses</span>
		</div>
		
		<nav class="header-nav">
			<a href="/" aria-current={path === '/' ? 'page' : undefined}>Home</a>
			<a href="/about" aria-current={path.startsWith('/about') ? 'page' : undefined}>About</a>
			<a href="/projects" aria-current={path.startsWith('/projects') ? 'page' : undefined}>Projects</a>
			<a href="/blog" aria-current={path.startsWith('/blog') ? 'page' : undefined}>Blog</a>
			<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
				🌙
			</button>
		</nav>
	</div>
	<!-- Space for future navigation items -->
    
</header>

<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		padding: 20px;
		pointer-events: none;
		background: var(--surface);
		backdrop-filter: blur(20px);
		border-bottom: 2px solid var(--border);
		box-shadow: 0 4px 20px var(--shadow);
	}

	.container {
		pointer-events: auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
	}

	.profile-section {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.avatar-link {
		display: inline-block;
		text-decoration: none;
	}

	.profile-name {
        font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		color: var(--primary);
		font-size: 18px;
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.profile-avatar {
		pointer-events: auto;
	}

	.header-nav {
		display: flex;
		gap: 24px;
		align-items: center;
	}

	.header-nav a {
		color: var(--primary);
		text-decoration: none;
		padding: 6px 4px;
		font-weight: 600;
		position: relative;
		transition: color 0.2s ease;
	}

	.header-nav a::after {
		content: '';
		position: absolute;
		left: 4px;
		right: 4px;
		bottom: 2px;
		height: 2px;
		background: var(--accent);
		transform: scaleX(0);
		transform-origin: center;
		transition: transform 0.25s ease;
	}

	.header-nav a:hover,
	.header-nav a[aria-current="page"] {
		color: var(--accent-strong);
	}

	.header-nav a:hover::after,
	.header-nav a[aria-current="page"]::after {
		transform: scaleX(1);
	}

	.theme-toggle {
		background: transparent;
		border: none;
		padding: 4px 6px;
		font-size: 18px;
		cursor: pointer;
		line-height: 1;
		transition: transform 0.2s ease;
	}

	.theme-toggle:hover {
		transform: scale(1.15);
	}

	.avatar-img {
		width: 50px;
		height: 50px;
		border-radius: 50%;
		object-fit: cover;
		border: 3px solid rgba(255, 255, 255, 0.9);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.avatar-img:hover {
		transform: scale(1.05);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
	}

	/* Mobile responsive */
	@media (max-width: 640px) {
		.profile-name {
			display: none;
		}

		.profile-section {
			gap: 0;
		}
	}

	@media (max-width: 768px) {
		.header-nav {
			gap: 16px;
		}

		.header-nav a {
			font-size: 14px;
		}

		.profile-name {
			font-size: 16px;
		}

		.profile-section {
			gap: 10px;
		}
	}

	@media (max-width: 480px) {
		header {
			padding: 15px;
		}

		.header-nav {
			gap: 12px;
		}

		.header-nav a {
			font-size: 13px;
		}
		
		.avatar-img {
			width: 40px;
			height: 40px;
		}

		.profile-name {
			font-size: 14px;
		}

		.profile-section {
			gap: 8px;
		}
	}
</style>
