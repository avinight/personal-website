---
import { bio } from '../data/bio';
import { Icon } from 'astro-icon/components';
---

<div id="container">
	<main>
		<div id="hero">
			<h1 id="greeting">{bio.greeting}</h1>

			<section class="box">
				{bio.about.map(paragraph => <p>{paragraph}</p>)}
			</section>

			<section class="box">
				<h2>{bio.techStack.heading}</h2>
				<div class="icon-grid">
					{bio.techStack.languages.map(lang => (
						<span class="tech-icon" title={lang.name} aria-label={lang.name}>
							<Icon name={lang.iconName} />
						</span>
					))}
				</div>
			</section>
		</div>
	</main>
</div>

<style>
	#container {
		min-height: 100vh;
	}

	main {
		min-height: 100vh;
		display: flex;
		justify-content: center;
		align-items: flex-start;
		padding: clamp(12px, 3vw, 24px);
		margin-top: clamp(80px, 10vh, 110px);
		box-sizing: border-box;
	}

	#hero {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		padding: clamp(8px, 2vw, 16px);
		max-width: 800px;
		width: 100%;
		gap: clamp(14px, 2.5vw, 24px);
	}

	h1 {
		display: inline-block;
		overflow: hidden;
		white-space: nowrap;
		border-right: 3px solid var(--primary);
		width: 0;
		font-size: clamp(26px, 5vw, 42px);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.2;
		margin-top: 0.25em;
		color: var(--primary);
		animation:
			typing 1.8s steps(18, end) 0.4s forwards,
			blink 0.7s step-end 2.2s 3 forwards;
	}

	@keyframes typing {
		to { width: var(--end-width, 18ch); }
	}

	@keyframes blink {
		from, to { border-right-color: transparent; }
		50% { border-right-color: var(--primary); }
	}

	@media (prefers-reduced-motion: reduce) {
		h1 {
			width: auto;
			border-right: none;
			animation: none;
		}
	}

	h2 {
		margin: 0 0 0.75em;
		font-weight: 600;
		color: var(--accent-strong);
		font-size: clamp(17px, 2.5vw, 20px);
	}

	.icon-grid {
		display: flex;
		flex-wrap: wrap;
		gap: clamp(12px, 2vw, 16px);
	}

	.tech-icon {
		color: var(--text-muted);
		transition: color 0.2s ease, transform 0.2s ease;
		display: flex;
	}

	.tech-icon:hover {
		color: var(--primary);
		transform: scale(1.15);
	}

	.tech-icon :global(svg) {
		width: clamp(22px, 3vw, 28px);
		height: clamp(22px, 3vw, 28px);
	}

	.box {
		padding: clamp(16px, 3vw, 24px);
		background: var(--surface);
		border-radius: 16px;
		border: 1px solid var(--border);
		border-left: 3px solid var(--accent);
		box-shadow: 0 4px 12px var(--shadow);
		width: 100%;
		box-sizing: border-box;
	}

	.box p {
		margin: 0;
		line-height: 1.75;
		letter-spacing: -0.006em;
	}

	.box p:first-child {
		font-size: clamp(16px, 2.5vw, 19px);
		font-weight: 500;
		color: var(--text);
	}

	.box p + p {
		margin-top: clamp(10px, 1.5vw, 14px);
		font-size: clamp(14px, 2vw, 17px);
		color: var(--text-muted);
	}

	/* Landscape phones */
	@media screen and (max-height: 500px) and (orientation: landscape) {
		main {
			margin-top: 70px;
			min-height: unset;
			padding-bottom: 40px;
		}

		h1 {
			font-size: 24px;
		}
	}

	/* Small mobile */
	@media screen and (max-width: 480px) {
		main {
			padding: 12px;
		}

		#hero {
			padding: 4px;
		}

		.box {
			border-radius: 12px;
		}
	}
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const h1 = document.getElementById('greeting');
    if (!h1 || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    function measureWidth(): number {
      const clone = h1!.cloneNode(true) as HTMLElement;
      Object.assign(clone.style, {
        position: 'fixed',
        top: '-9999px',
        left: '0',
        visibility: 'hidden',
        animation: 'none',
        width: 'max-content',
        maxWidth: 'none',
      });
      document.body.appendChild(clone);
      const w = clone.getBoundingClientRect().width;
      document.body.removeChild(clone);
      return w;
    }

    h1.style.setProperty('--end-width', measureWidth() + 'px');

    h1.addEventListener('animationend', (e) => {
      if ((e as AnimationEvent).animationName === 'typing') {
        h1!.style.width = 'max-content';
      }
    });

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        h1!.style.setProperty('--end-width', measureWidth() + 'px');
      }, 100);
    });
  });
</script>
