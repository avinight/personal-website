---
import background from '../assets/background.svg';
import 'katex/dist/katex.min.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Frederick Meneses - Software Engineer</title>
	</head>
	<body>
		<img id="bg-image" src={background.src} alt="" fetchpriority="high" />
		<div id="bg-overlay"></div>
		<div id="page-content">
			<slot />
		</div>
		<span class="katex-version-check" aria-hidden="true">
			<span class="katex">
				<span class="katex-mathml">The KaTeX stylesheet is not loaded!</span>
				<span class="katex-version rule">KaTeX stylesheet version: </span>
			</span>
		</span>
		<script type="module" src="/katex-auto-render.js"></script>
	</body>
</html>

<style is:global>
	:root {
		--bg-base: #F8EDD9;
		--surface: rgba(255, 249, 238, 0.92);
		--border: rgba(192, 98, 58, 0.25);
		--border-strong: rgba(192, 98, 58, 0.5);
		--text: #3D2817;
		--text-muted: #6B5444;
		--primary: #C0623A;
		--primary-strong: #9A4526;
		--primary-soft: rgba(192, 98, 58, 0.12);
		--primary-soft-hover: rgba(192, 98, 58, 0.22);
		--accent: #2E7D7E;
		--accent-strong: #205657;
		--accent-soft: rgba(46, 125, 126, 0.14);
		--accent-soft-hover: rgba(46, 125, 126, 0.24);
		--shadow: rgba(102, 52, 25, 0.12);
		--shadow-strong: rgba(102, 52, 25, 0.22);
	}

	:root.dark {
		--bg-base: #1C2A3A;
		--surface: rgba(38, 52, 72, 0.88);
		--border: rgba(229, 138, 91, 0.28);
		--border-strong: rgba(229, 138, 91, 0.55);
		--text: #EFE4D3;
		--text-muted: #BCAD98;
		--primary: #E58A5B;
		--primary-strong: #F2A581;
		--primary-soft: rgba(229, 138, 91, 0.15);
		--primary-soft-hover: rgba(229, 138, 91, 0.28);
		--accent: #7FC8C9;
		--accent-strong: #A3DEE0;
		--accent-soft: rgba(127, 200, 201, 0.16);
		--accent-soft-hover: rgba(127, 200, 201, 0.28);
		--shadow: rgba(0, 0, 0, 0.4);
		--shadow-strong: rgba(0, 0, 0, 0.55);
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
	}

	#bg-image {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		object-fit: cover;
	}

	#bg-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 1;
		background-color: var(--bg-base);
		opacity: 0.88;
	}

	#page-content {
		position: relative;
		z-index: 2;
	}

	.katex-version-check {
		display: none;
	}
</style>
